# Create an app at https://developer.manifoldxyz.dev/
# Redirect URI: https://nikxart.xyz
NEXT_PUBLIC_MANIFOLD_APP_NAME=Nikxart
NEXT_PUBLIC_MANIFOLD_CLIENT_ID=your_manifold_client_id_here

# Required for Manifold Connect peer (same as manifold.xyz claim pages use for WalletConnect)
# Create at https://cloud.walletconnect.com — add https://nikxart.xyz to allowed domains
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_32_char_walletconnect_project_id_here